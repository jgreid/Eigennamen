# Docker Compose secrets
# Copy this file: cp .env.example .env
# Then edit .env with your own values (it is gitignored).
# For all server configuration options, see server/.env.example

# Redis password (required for Docker)
REDIS_PASSWORD=replace-me-with-a-strong-password

# JWT signing secret — at least 32 characters (required)
JWT_SECRET=replace-me-with-at-least-32-characters-of-random

# CORS origin (optional, defaults to http://localhost:3000)
# CORS_ORIGIN=http://localhost:3000
