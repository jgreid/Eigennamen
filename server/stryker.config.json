{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-core.json",
  "mutate": [
    "src/services/**/*.ts",
    "!src/services/game/luaGameOps.ts",
    "src/utils/sanitize.ts",
    "src/utils/timeout.ts",
    "src/utils/parseJSON.ts",
    "src/errors/GameError.ts"
  ],
  "testRunner": "jest",
  "jest": {
    "configFile": "jest.config.ts.js",
    "projectType": "custom"
  },
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "timeoutMS": 30000,
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "concurrency": 2,
  "tempDirName": ".stryker-tmp"
}
