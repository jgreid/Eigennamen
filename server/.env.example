# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# LOG_FORMAT=json              # Log output format: "json" for structured logging (default in production), omit for pretty-print

# Proxy Trust
# Enable if behind a reverse proxy (nginx, AWS ALB, etc.) to trust X-Forwarded-For headers.
# Automatically enabled on Fly.io and Heroku.
# TRUST_PROXY=true

# Redis
# Use redis:// for local, rediss:// for TLS (Fly.io Upstash)
REDIS_URL=redis://localhost:6379
# REDIS_TLS_REJECT_UNAUTHORIZED=false  # Set to false to allow self-signed TLS certs (dev only, NOT for production)
# MEMORY_MODE_ALLOW_FLY=true           # Allow REDIS_URL=memory on Fly.io (normally blocked for safety)

# Authentication
# IMPORTANT: Generate a strong secret for production! Example: openssl rand -base64 32
JWT_SECRET=CHANGE-ME-generate-a-strong-secret-with-openssl-rand
# Note: Token expiry is hardcoded to 24h in config/jwt.ts (this env var is not read)

# CORS
# Use specific origin(s) in production. Comma-separated for multiple origins.
# CRITICAL: Never use * in production - the server will refuse to start.
# Examples:
#   CORS_ORIGIN=https://your-app.fly.dev
#   CORS_ORIGIN=https://your-app.fly.dev,https://custom-domain.com
CORS_ORIGIN=*

# Admin Dashboard (optional)
# Set a strong password to enable the /admin dashboard
# If not set, the admin dashboard requires no authentication (not recommended for production)
# ADMIN_PASSWORD=your-secure-admin-password

# Session Security
# Allow reconnection from a different IP address than the original session.
# Default: false (reconnections from different IPs are rejected).
# Set to true if players frequently switch networks (e.g., mobile, VPN).
# SECURITY NOTE: Enabling this widens the session hijacking window since
# stolen reconnection tokens can be used from any IP address.
# ALLOW_IP_MISMATCH=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_MAX_ENTRIES=10000  # Maximum tracked rate-limit entries before cleanup (default: 10000)

# Room Configuration (for reference only - values are hardcoded in config/constants.ts)
# To change these values, edit server/src/config/constants.ts
# ROOM_CODE_LENGTH=6
# ROOM_MAX_PLAYERS=20
# ROOM_EXPIRY_HOURS=24

# Instance Identification
# Custom instance ID for multi-instance deployments (used in logs, metrics, audit, distributed locks).
# Falls back to FLY_ALLOC_ID or 'local' if not set.
# INSTANCE_ID=my-instance-1

# ============================================
# Fly.io Specific Configuration
# ============================================
# These are automatically set by Fly.io runtime:
# FLY_ALLOC_ID - Instance allocation ID
# FLY_REGION - Deployment region (e.g., iad, lhr)
# FLY_APP_NAME - Application name
#
# Set these secrets using: fly secrets set KEY=value
# Required for production:
# - REDIS_URL (from Fly Redis/Upstash)
# - JWT_SECRET (generate a secure random string)
