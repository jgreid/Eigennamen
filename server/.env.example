# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# LOG_FORMAT=json              # Log output format: "json" for structured logging (default in production), omit for pretty-print

# Proxy Trust
# Enable if behind a reverse proxy (nginx, AWS ALB, etc.) to trust X-Forwarded-For headers.
# Automatically enabled on Fly.io and Heroku.
# TRUST_PROXY=true

# Redis
# Use redis:// for local, rediss:// for TLS (Fly.io Upstash)
REDIS_URL=redis://localhost:6379

# Authentication
# IMPORTANT: Generate a strong secret for production! Example: openssl rand -base64 32
JWT_SECRET=CHANGE-ME-generate-a-strong-secret-with-openssl-rand
# Note: Token expiry is hardcoded to 24h in config/jwt.ts (this env var is not read)

# CORS
# Use specific origin(s) in production. Comma-separated for multiple origins.
# CRITICAL: Never use * in production - the server will refuse to start.
# Examples:
#   CORS_ORIGIN=https://your-app.fly.dev
#   CORS_ORIGIN=https://your-app.fly.dev,https://custom-domain.com
CORS_ORIGIN=*

# Admin Dashboard (optional)
# Set a strong password to enable the /admin dashboard
# If not set, the admin dashboard rejects every request with 401 ADMIN_NOT_CONFIGURED — it fails closed, not open
# ADMIN_PASSWORD=your-secure-admin-password

# Session Security
# Allow reconnection from a different IP address than the original session.
# Default: false (reconnections from different IPs are rejected).
# Set to true if players frequently switch networks (e.g., mobile, VPN).
# SECURITY NOTE: Enabling this widens the session hijacking window since
# stolen reconnection tokens can be used from any IP address.
# ALLOW_IP_MISMATCH=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_MAX_ENTRIES=10000  # Maximum tracked rate-limit entries before cleanup (default: 10000)
# GLOBAL_IP_RATE_LIMIT_MAX=300         # Max socket events per IP across ALL event types per window (default: 300)
# GLOBAL_IP_RATE_LIMIT_WINDOW_MS=60000 # Window (ms) for the global per-IP socket cap (default: 60000)
# LOADTEST_RELAX_RATE_LIMITS=true      # Relax per-IP socket rate limits for the bundled load tests. IGNORED in production (fail-closed).

# Connection Limits
# MAX_CONNECTIONS_PER_IP=10            # Max concurrent socket connections from a single IP (default: 10)

# Session Tokens
# RECONNECT_TOKEN_TTL_SECONDS=300      # Reconnection-token lifetime in seconds (default: 300, range: 60-1800)

# Room Configuration (for reference only - values are hardcoded in config/constants.ts)
# To change these values, edit server/src/config/constants.ts
# ROOM_CODE_LENGTH=6
# ROOM_MAX_PLAYERS=20
# ROOM_EXPIRY_HOURS=24

# Instance Identification
# Custom instance ID for multi-instance deployments (used in logs, metrics, audit, distributed locks).
# Falls back to FLY_ALLOC_ID or 'local' if not set.
# INSTANCE_ID=my-instance-1

# Advanced / Internal Configuration
# These are rarely needed and have sensible defaults.
# EMBEDDED_REDIS_TIMEOUT_MS=5000   # Timeout (ms) waiting for embedded Redis to start in memory mode (min 1000)
# MEMORY_MODE_ALLOW_FLY=true       # Allow REDIS_URL=memory on Fly.io (normally blocked for safety)
# REDIS_TLS_REJECT_UNAUTHORIZED=false  # Allow self-signed TLS certs for Redis (dev only, NOT for production)

# ============================================
# Fly.io Specific Configuration
# ============================================
# These are automatically set by Fly.io runtime:
# FLY_ALLOC_ID - Instance allocation ID
# FLY_REGION - Deployment region (e.g., iad, lhr)
# FLY_APP_NAME - Application name
#
# Set these secrets using: fly secrets set KEY=value
# Required for production:
# - REDIS_URL (from Fly Redis/Upstash)
# - JWT_SECRET (generate a secure random string)

# ============================================
# Intelligent Bots — Semantic Embeddings (optional)
# ============================================
# Bots default to an offline-baked association table (no assets, deterministic).
# To upgrade the spymaster/clicker to real word embeddings, point this at a
# word-vectors file in word2vec / GloVe / fastText / ConceptNet-Numberbatch text
# format. If unset, a previously downloaded/baked file is AUTO-DETECTED at the
# well-known locations (src/bots/data/board-vectors.vec, embeddings/vectors.vec,
# the raw GloVe/fastText downloads) — so a one-time `npm run bots:embeddings`
# upgrades every later `npm run dev`. Set to `off` to force the table backend.
# If the file is unreadable, bots transparently fall back to the table.
# Easiest: `npm run dev:bots` downloads a model and sets this for you (or
# `npm run bots:embeddings` to only fetch). For manual control / Numberbatch use
# scripts/fetch-bot-embeddings.sh. Files are saved under git-ignored server/src/bots/data/.
# BOT_EMBEDDINGS_PATH=src/bots/data/glove.6B.100d.vec
# BOT_EMBEDDINGS_MAX_WORDS=50000   # cap vectors loaded into memory (default 50000)
# BOT_EMBEDDINGS_VOCAB_CAP=2000    # cap spymaster clue candidates (default 2000)
# --- LLM-backed bots (optional, strongest tier — see docs/BOT_LLM.md) ---
# Naming a model turns the layer on: bots consult Claude before each decision
# (the LLM proposes, the deterministic safety machinery verifies). Credentials
# resolve via the Anthropic SDK's standard chain (ANTHROPIC_API_KEY). Any
# failure/timeout degrades to normal bot play — never a stalled game.
# ANTHROPIC_API_KEY=sk-ant-...
# BOT_LLM_MODEL=claude-sonnet-5
# BOT_LLM_TIMEOUT_MS=8000          # per-call budget (default 8000, min 1000)

# Directory of prepared per-word-list semantic maps (npm run bots:map output).
# Loaded and merged over the baked table so bots reach full strength on custom
# word lists. See docs/BOT_SEMANTIC_MAPS.md. (default: src/bots/data/semantic-maps)
# BOT_SEMANTIC_MAPS_DIR=src/bots/data/semantic-maps
