# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (PostgreSQL)
# Main connection URL (can be pooled via PgBouncer)
DATABASE_URL=postgresql://codenames:password@localhost:5432/codenames
# Direct connection URL for migrations (bypasses PgBouncer)
# Required for Fly.io with Supabase/Neon databases that use connection pooling
DATABASE_DIRECT_URL=postgresql://codenames:password@localhost:5432/codenames

# Redis
# Use redis:// for local, rediss:// for TLS (Fly.io Upstash)
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
# Use specific origin in production, e.g., https://your-app.fly.dev
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Room Configuration
ROOM_CODE_LENGTH=6
ROOM_MAX_PLAYERS=20
ROOM_EXPIRY_HOURS=24

# Feature Flags
ENABLE_ACCOUNTS=false
ENABLE_CHAT=true
ENABLE_SPECTATORS=true

# ============================================
# Fly.io Specific Configuration
# ============================================
# These are automatically set by Fly.io runtime:
# FLY_ALLOC_ID - Instance allocation ID
# FLY_REGION - Deployment region (e.g., iad, lhr)
# FLY_APP_NAME - Application name
#
# Set these secrets using: fly secrets set KEY=value
# Required for production:
# - DATABASE_URL (from Fly Postgres or external)
# - DATABASE_DIRECT_URL (direct connection for migrations)
# - REDIS_URL (from Fly Redis/Upstash)
# - JWT_SECRET (generate a secure random string)
