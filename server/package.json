{
  "name": "die-eigennamen-server",
  "version": "2.3.0",
  "description": "Real-time multiplayer server for Die Eigennamen",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "predev": "tsc -p tsconfig.frontend.json",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.frontend.json && cp src/scripts/*.lua dist/scripts/",
    "build:check": "tsc --noEmit && tsc --noEmit -p tsconfig.frontend.json",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean && npm run typecheck",
    "test": "jest --config jest.config.ts.js",
    "test:watch": "jest --config jest.config.ts.js --watch",
    "test:coverage": "jest --config jest.config.ts.js --coverage",
    "test:frontend": "jest --config jest.config.ts.js --selectProjects frontend",
    "test:backend": "jest --config jest.config.ts.js --selectProjects backend",
    "build:frontend": "tsc -p tsconfig.frontend.json",
    "build:frontend:bundle": "node esbuild.config.js",
    "build:frontend:watch": "node esbuild.config.js --watch",
    "build:prod": "tsc -p tsconfig.build.json && node esbuild.config.js && cp src/scripts/*.lua dist/scripts/",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:chromium": "npx playwright test --project=chromium",
    "test:e2e:install": "npx playwright install",
    "lint": "eslint --ext .ts src/",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.frontend.json",
    "setup": "../scripts/dev-setup.sh",
    "health": "../scripts/health-check.sh",
    "predeploy": "../scripts/pre-deploy-check.sh",
    "redis:inspect": "../scripts/redis-inspect.sh",
    "test:mutation": "npx stryker run",
    "test:mutation:dry": "npx stryker run --dryRunOnly",
    "loadtest": "node loadtest/stress-test.js",
    "loadtest:memory": "node loadtest/memory-leak-test.js"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.2.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.6.10",
    "socket.io": "^4.7.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/jest-runner": "^8.0.0",
    "@stryker-mutator/typescript-checker": "^8.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.24",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "socket.io-client": "^4.7.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "comment": "Primary config is jest.config.ts.js — this section is intentionally empty"
  }
}
