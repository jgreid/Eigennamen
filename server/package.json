{
  "name": "eigennamen-server",
  "version": "5.4.2",
  "description": "Real-time multiplayer server for Eigennamen",
  "author": "Jeffrey Reid (https://github.com/jgreid)",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "predev": "tsc -p tsconfig.frontend.json --noEmit",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.build.json && node esbuild.config.js && cp src/scripts/*.lua dist/scripts/",
    "build:check": "tsc --noEmit && tsc --noEmit -p tsconfig.frontend.json",
    "clean": "rm -rf dist public/js/modules/frontend public/js/modules/shared public/js/modules/chunks",
    "prebuild": "npm run clean && npm run typecheck",
    "test": "jest --config jest.config.ts.js",
    "test:watch": "jest --config jest.config.ts.js --watch",
    "test:coverage": "jest --config jest.config.ts.js --coverage",
    "test:frontend": "jest --config jest.config.ts.js --selectProjects frontend",
    "test:backend": "jest --config jest.config.ts.js --selectProjects backend",
    "build:frontend": "node esbuild.config.js",
    "build:frontend:watch": "node esbuild.config.js --watch",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:chromium": "npx playwright test --project=chromium",
    "test:e2e:install": "npx playwright install",
    "lint": "eslint --ext .ts src/ --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\" \"e2e/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"e2e/**/*.js\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.frontend.json",
    "setup": "../scripts/dev-setup.sh",
    "health": "../scripts/health-check.sh",
    "predeploy": "../scripts/pre-deploy-check.sh",
    "redis:inspect": "../scripts/redis-inspect.sh",
    "loadtest": "node loadtest/stress-test.js",
    "loadtest:memory": "node loadtest/memory-leak-test.js"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.2.1",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "redis": "^5.11.0",
    "socket.io": "^4.7.2",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.8.1",
    "socket.io-client": "^4.7.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "jest": {
    "comment": "Primary config is jest.config.ts.js — this section is intentionally empty"
  }
}
