{
  "compilerOptions": {
    // Target and module settings
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node10",
    // TS 6.0 deprecates the 'node10' resolution and turns it into a hard error.
    // node10 remains correct for this CommonJS server build, so silence the
    // deprecation until a deliberate migration to 'node16'/'nodenext'. Without
    // this, both `tsc --noEmit` and every ts-jest suite fail to compile.
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    // Strict type checking (all enabled for maximum safety)
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "useUnknownInCatchVariables": true,
    "alwaysStrict": true,

    // Additional checks
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,

    // Build settings
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,
    "preserveConstEnums": true,

    // Resolution
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,

    // Type roots
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "src/__tests__",
    "src/frontend"
  ]
}
